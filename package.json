{
  "name": "universal-connectors-docs",
  "version": "1.0.0",
  "private": true,
  "description": "Docusaurus GitHub Pages site for the Universal Connectors documentation.",
  "scripts": {
    "prepare:docusaurus": "node scripts/generate-docusaurus-content.mjs",
    "prestart": "npm run prepare:docusaurus",
    "start": "docusaurus start --host 0.0.0.0",
    "prebuild": "npm run prepare:docusaurus",
    "build": "docusaurus build --out-dir pages-build",
    "postbuild": "node scripts/mark-static-download-links.mjs",
    "serve": "docusaurus serve pages-build"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/faster": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@docusaurus/theme-mermaid": "^3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.1",
    "@ibm/plex": "^6.4.1",
    "@mdx-js/react": "^3.1.0",
    "clsx": "^2.1.1",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
